<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension point="org.eclipse.ui.commands">
      <command
            id="com.sdp.edt.storagehelper.ui.pullCommand"
            name="Pull">
      </command>
      <command
            id="com.sdp.edt.storagehelper.ui.pushCommand"
            name="Push">
      </command>
   </extension>
   <extension point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="toolbar:org.eclipse.team.ui.GenericHistoryView?after=additions">
         <command
               commandId="com.sdp.edt.storagehelper.ui.pullCommand"
               label="Pull"
               style="push"
               tooltip="Получить из хранилища"
               icon="icons/pull.png">
         </command>
         <command
               commandId="com.sdp.edt.storagehelper.ui.pushCommand"
               icon="icons/push.png"
               label="Push"
               style="push"
               tooltip="Отправить в хранилище">
         </command>
      </menuContribution>
   </extension>
   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="com.sdp.edt.storagehelper.ui.pullCommand"
            class="com.sdp.edt.storagehelper.ui.PullAction">
      </handler>
      <handler
            class="com.sdp.edt.storagehelper.ui.PushAction"
            commandId="com.sdp.edt.storagehelper.ui.pushCommand">
      </handler>
   </extension>
</plugin>
